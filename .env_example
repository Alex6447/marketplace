# Шаблон переменных окружения. Скопируйте в .env и при необходимости поправьте.
# Значения рассчитаны на запуск кода с ХОСТ-машины (localhost). Внутри docker-сети
# хосты сервисов — это их имена (postgres/redis/minio); такие переменные заданы
# прямо в docker-compose.yml.

# --- PostgreSQL ---
# Формат: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL='postgresql://postgres:postgres@localhost:5432/marketplace'
# Используются docker-compose при поднятии контейнера postgres:
POSTGRES_USER='postgres'
POSTGRES_PASSWORD='postgres'
POSTGRES_DB='marketplace'

# --- Redis (брокер и бэкенд Celery) ---
REDIS_URL='redis://localhost:6379/0'
# Выполнять Celery-задачи синхронно в процессе, без брокера (для тестов/офлайна).
# В обычной работе оставлять пустым/false — задачи уходят в worker через Redis.
CELERY_TASK_ALWAYS_EAGER=''

# --- MinIO / S3 (хранилище изображений) ---
MINIO_ROOT_USER='minioadmin'
MINIO_ROOT_PASSWORD='minioadmin'
S3_ENDPOINT='http://localhost:9000'
S3_ACCESS_KEY='minioadmin'
S3_SECRET_KEY='minioadmin'
S3_BUCKET='marketplace'
# Регион для подписи AWS SigV4. Для MinIO значение произвольно, но должно быть задано.
S3_REGION='us-east-1'

# --- Провайдеры генерации (LLM / Image) ---
# Режим развёртывания (справочно): hosted | local | hybrid (docs/plan.md, 4.1).
DEPLOYMENT_MODE='hosted'
# Выбор реализаций. 'echo' — офлайн-заглушки без сети/ключей (дефолт для старта).
# Hosted: LLM_PROVIDER='anthropic' (нужен ANTHROPIC_API_KEY),
#         IMAGE_PROVIDER='gemini' (нужен GEMINI_API_KEY).
LLM_PROVIDER='echo'
IMAGE_PROVIDER='echo'
# Matting (стадия [4], удаление фона/маска): 'simple' — офлайн-кеинг по цвету фона
# (Pillow, без GPU). Локальные 'birefnet'/'sam2' — Этап 6.
MATTING_PROVIDER='simple'
# Модели (пусто → дефолт выбранного провайдера).
LLM_MODEL=''
IMAGE_MODEL=''
MATTING_MODEL=''
# Ключи доступа к hosted-API (нужны только для соответствующих провайдеров).
ANTHROPIC_API_KEY=''
GEMINI_API_KEY=''
BFL_API_KEY=''

# --- Наложение текста (стадия [6]) ---
# Backend движка текста: 'pillow' — офлайн-fallback без браузера (дефолт),
# 'playwright' — основной режим HTML/CSS через headless Chromium (extra воркера
# 'render' + `playwright install chromium`).
TEXT_RENDERER='pillow'
# Путь к TTF-шрифту с кириллицей для Pillow-бэкенда (пусто → автоподбор системного).
TEXT_RENDER_FONT=''

# --- Пайплайн ---
# Контент-адресуемый кэш артефактов стадий ([4]/[5]): артефакт переиспользуется,
# если входы стадии (фото/вырез/референсы + концепция + параметры) не изменились —
# основа «правки только нужной стадии». Пусто/false → пересчитывать всегда.
PIPELINE_CACHE_ENABLED='true'
# Префикс ключей кэша в бакете (изоляция от пользовательских артефактов).
PIPELINE_CACHE_PREFIX='cache'

# --- Наблюдаемость (Этап 5) ---
# Уровень логирования API и worker: DEBUG | INFO | WARNING | ERROR (дефолт INFO).
LOG_LEVEL='INFO'
